#include <Servo.h>

Servo miServo;

unsigned long ultimoLatido = 0;
int intervaloLatido = 1000; // 60 bpm (1 latido por segundo)

void setup() {
  // No activamos el servo aquí, solo cuando toque latido
}

void loop() {
  // ¿Toca latido?
  if (millis() - ultimoLatido > intervaloLatido) {
    ultimoLatido = millis();

    // Activar servo solo durante el latido
    miServo.attach(9);       // activa el servo
    miServo.write(120);      // pequeño golpe
    delay(100);
    miServo.write(90);       // regresa al centro
    delay(100);
    miServo.detach();        // se apaga hasta el siguiente latido
  }
}

